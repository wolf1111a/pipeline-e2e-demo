{
  "schemaVersion": "2026-standalone-stage-v2",
  "pluginVersion": "2.0.0",
  "build": {
    "command": "node e2e-build.cjs && npm ci && npm run synth",
    "packageCommand": "node e2e-package.cjs && npm ci"
  },
  "deployment": {
    "deploy": {
      "kind": "cdk-node",
      "appPath": ".",
      "outputs": {
        "appUrl": "FrontendUrl",
        "webBucketName": "FrontendBucketName",
        "cloudFrontDistributionId": "FrontendDistributionId"
      }
    },
    "seed": {
      "command": "test -s cdk.json"
    },
    "verify": {
      "command": "test -s cdk.json"
    }
  },
  "test": {
    "command": "test -s cdk.json"
  }
}
