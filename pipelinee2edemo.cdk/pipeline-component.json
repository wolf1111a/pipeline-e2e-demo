{
  "schemaVersion": "2026-standalone-stage-v1",
  "componentKey": "pipeline-e2e-demo-cdk",
  "name": "pipeline-e2e-demo-cdk",
  "type": "cdk_infra",
  "pluginId": "cdk-node",
  "pluginVersion": "2.0.0",
  "build": {
    "command": "node e2e-build.cjs && npm ci && npm run synth",
    "packageCommand": "node e2e-package.cjs && npm ci"
  },
  "deployment": {
    "deploy": {
      "kind": "cdk-node",
      "appPath": "."
    },
    "seed": {
      "command": "test -s cdk.json"
    },
    "verify": {
      "command": "test -s cdk.json"
    }
  },
  "test": {
    "command": "test -s cdk.json"
  }
}
