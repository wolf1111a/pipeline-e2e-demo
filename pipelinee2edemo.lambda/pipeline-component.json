{
  "schemaVersion": "2026-standalone-stage-v2",
  "pluginVersion": "2.0.0",
  "build": {
    "command": "npm test",
    "packageCommand": "npm run build"
  },
  "deployment": {
    "deploy": {
      "kind": "aws-lambda-artifact",
      "artifactPath": "lambda.zip"
    },
    "verify": {
      "command": "test -s lambda.zip && unzip -tq lambda.zip"
    }
  },
  "test": {
    "command": "npm test"
  }
}
