{
  "schemaVersion": "2026-standalone-stage-v1",
  "componentKey": "pipeline-e2e-demo-lambda",
  "name": "pipeline-e2e-demo-lambda",
  "type": "lambda",
  "pluginId": "aws-lambda",
  "pluginVersion": "2.0.0",
  "build": {
    "command": "npm test",
    "packageCommand": "npm run build"
  },
  "deployment": {
    "deploy": {
      "kind": "aws-lambda-artifact",
      "artifactPath": "lambda.zip"
    },
    "verify": {
      "command": "test -s lambda.zip && unzip -tq lambda.zip"
    }
  },
  "test": {
    "command": "npm test"
  }
}
