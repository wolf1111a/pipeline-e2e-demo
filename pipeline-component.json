{
  "schemaVersion": "2026-07-14",
  "componentKey": "pipeline-e2e-shell",
  "name": "pipeline-e2e-shell",
  "type": "custom",
  "triggerPaths": ["README.md", "pipeline-component.json", "version.json"],
  "branch": "main",
  "pluginId": "shell-command",
  "pluginVersion": "1.0.0",
  "build": {
    "dependsOn": [],
    "config": {
      "command": "printf 'build ok\\n'",
      "packageCommand": "printf 'package ok\\n'"
    }
  },
  "deploymentTarget": {
    "deployCommand": "printf 'deploy ok for %s\\n' \"$PIPELINE_ENVIRONMENT_ID\""
  },
  "environments": {
    "beta": {
      "seedCommand": "printf 'seed ok for beta\\n'"
    },
    "prod": {
      "seedCommand": "printf 'seed ok for prod\\n'"
    }
  },
  "test": {
    "command": "printf 'verify ok for %s\\n' \"$PIPELINE_ENVIRONMENT_ID\""
  }
}
