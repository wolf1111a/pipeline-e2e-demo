{
  "schemaVersion": "2026-standalone-stage-v2",
  "pluginVersion": "2.0.0",
  "build": {
    "command": "npm ci && npm run build",
    "packageCommand": "npm ci && npm run build"
  },
  "deployment": {
    "deploy": {
      "kind": "frontend-static",
      "buildOutputPath": "dist",
      "preserveObjects": [
        "config.js"
      ],
      "inputs": {
        "bucketName": {
          "component": "pipeline-e2e-demo-cdk",
          "output": "webBucketName"
        },
        "cloudFrontDistributionId": {
          "component": "pipeline-e2e-demo-cdk",
          "output": "cloudFrontDistributionId"
        }
      }
    },
    "verify": {
      "command": "test -s dist/index.html"
    }
  },
  "test": {
    "command": "test -s dist/index.html"
  }
}
