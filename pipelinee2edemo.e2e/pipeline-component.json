{
  "schemaVersion": "2026-standalone-stage-v2",
  "pluginVersion": "1.0.0",
  "build": {
    "command": "node --test",
    "packageCommand": "test -s test-manifest.json"
  },
  "deployment": {
    "gates": {
      "e2e": {
        "kind": "project-e2e",
        "artifactPath": ".",
        "testManifestPath": "test-manifest.json",
        "suites": {
          "essential": {
            "command": "node gate-e2e.mjs",
            "includeLabels": [
              "essential"
            ],
            "match": "any",
            "maxParallelShards": 2,
            "targetDurationSeconds": 60
          },
          "full": {
            "command": "node gate-e2e.mjs",
            "allTests": true,
            "maxParallelShards": 4,
            "targetDurationSeconds": 120
          }
        },
        "report": {
          "format": "pipeline-e2e-v1",
          "path": "reports/e2e.json",
          "requireLabelsOnEveryTest": true
        }
      }
    }
  },
  "test": {
    "command": "node --test"
  }
}
