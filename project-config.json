        "approvalExpiresAfterSeconds": 60,
        "timeoutSeconds": 3600,
        "subStages": {
          "deploy": {
            "timeoutSeconds": 1800
          },
          "seed": {
            "timeoutSeconds": 300
          },
          "verify": {
            "timeoutSeconds": 300,
            "overridePolicy": "forbidden"
          }
        }
      }
    },
    "prod": {
      "isProduction": true,
      "target": {
        "permissionTemplates": [
          "cdk_infra"
        ]
      },
      "deployment": {
        "requiresApproval": true,
        "approvalExpiresAfterSeconds": 3600,
        "timeoutSeconds": 3600,
        "subStages": {
          "deploy": {
            "timeoutSeconds": 1800
          },
          "seed": {
            "timeoutSeconds": 300
          },
          "verify": {
            "timeoutSeconds": 300,
            "overridePolicy": "forbidden"
          }
        }
      }
    }
  },
  "pipeline": {
    "stageDefaults": {
      "build": {
        "requiresApproval": false,
        "timeoutSeconds": 1200
      },
      "package": {
        "requiresApproval": false,
        "timeoutSeconds": 1200
      }
    }
  }
}
