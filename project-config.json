{
  "schemaVersion": "2026-standalone-stage-v1",
  "projectKey": "pipeline-e2e-demo",
  "displayName": "Pipeline Platform Standalone E2E",
  "github": {
    "owner": "wolf1111a",
    "repo": "pipeline-e2e-demo",
    "defaultBranch": "main"
  },
  "awsDefaults": {
    "accountId": "516703876684",
    "region": "us-east-1"
  },
  "sharedConfig": {
    "secretArn": "arn:aws:secretsmanager:us-east-1:516703876684:secret:pipeline-platform-e2e/config",
    "projectPath": "pipeline-e2e-demo"
  },
  "environmentOrder": [
    "beta",
    "prod"
  ],
  "environments": {
    "beta": {
      "isProduction": false,
      "target": {},
      "bindings": {
        "WEB_BUCKET_NAME": {
          "kind": "cdk-output",
          "componentKey": "pipeline-e2e-demo-cdk",
          "outputName": "FrontendBucketName"
        },
        "CLOUDFRONT_DISTRIBUTION_ID": {
          "kind": "cdk-output",
          "componentKey": "pipeline-e2e-demo-cdk",
          "outputName": "FrontendDistributionId"
        }
      },
      "secretBindings": {},
      "deployment": {
        "requiresApproval": true,
        "approvalExpiresAfterSeconds": 60,
        "timeoutSeconds": 3600,
        "subStages": {
          "deploy": {
            "timeoutSeconds": 1800
          },
          "seed": {
            "timeoutSeconds": 300
          },
          "verify": {
            "timeoutSeconds": 300,
            "overridePolicy": "forbidden"
          },
          "gates": {
            "e2e": {
              "enabled": true,
              "suite": "essential",
              "timeoutSeconds": 300,
              "overridePolicy": "project_admin"
            }
          }
        }
      }
    },
    "prod": {
      "isProduction": true,
      "target": {},
      "bindings": {
        "WEB_BUCKET_NAME": {
          "kind": "cdk-output",
          "componentKey": "pipeline-e2e-demo-cdk",
          "outputName": "FrontendBucketName"
        },
        "CLOUDFRONT_DISTRIBUTION_ID": {
          "kind": "cdk-output",
          "componentKey": "pipeline-e2e-demo-cdk",
          "outputName": "FrontendDistributionId"
        }
      },
      "secretBindings": {},
      "deployment": {
        "requiresApproval": true,
        "approvalExpiresAfterSeconds": 3600,
        "timeoutSeconds": 3600,
        "subStages": {
          "deploy": {
            "timeoutSeconds": 1800
          },
          "seed": {
            "timeoutSeconds": 300
          },
          "verify": {
            "timeoutSeconds": 300,
            "overridePolicy": "forbidden"
          },
          "gates": {
            "e2e": {
              "enabled": true,
              "suite": "full",
              "timeoutSeconds": 300,
              "overridePolicy": "forbidden"
            }
          }
        }
      }
    }
  },
  "pipeline": {
    "stageDefaults": {
      "build": {
        "requiresApproval": false,
        "timeoutSeconds": 1200
      },
      "package": {
        "requiresApproval": false,
        "timeoutSeconds": 1200
      }
    }
  }
}
